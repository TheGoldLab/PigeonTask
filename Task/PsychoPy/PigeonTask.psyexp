    </LoopInitiator>
    <Routine name="simple_demo"/>
    <LoopTerminator name="simple_demo_trial_loop"/>
    <LoopTerminator name="simple_demo_block_loop"/>
    <LoopInitiator loopType="TrialHandler" name="status_instruction_loop">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'sic_message': &quot;Great!\nNow that you have the basic idea, let's get started with the task.&quot;, 'sic_box_show': False, 'sic_box_x': 0, 'sic_box_y': 0, 'sic_box_width': 0, 'sic_box_height': 0}, {'sic_message': 'Your job is to determine, as quickly and accurately as possible, which seeds Petey will choose on each given trial, based on his initial movements.', 'sic_box_show': False, 'sic_box_x': 0, 'sic_box_y': 0, 'sic_box_width': 0, 'sic_box_height': 0}, {'sic_message': &quot;We show a line where Petey starts and a red line at Petey's midpoint so you can see exactly how far away he has moved in either direction.&quot;, 'sic_box_show': True, 'sic_box_x': 0, 'sic_box_y': 0, 'sic_box_width': 0.25, 'sic_box_height': 0.25}, {'sic_message': 'You will receive coins for each correct answer and lose coins for each incorrect answer. You also may have to pay coins to start each trial. You can get a bonus for reaching a certain number of coins.\nThis section shows the settings for the current block of trials.', 'sic_box_show': True, 'sic_box_x': -0.55, 'sic_box_y': -0.3, 'sic_box_width': 0.4, 'sic_box_height': 0.15}, {'sic_message': 'You will receive coins for each correct answer and lose coins for each incorrect answer. You also may have to pay coins to start each trial. You can get a bonus for reaching a certain number of coins.\nThis bar tells you how many coins you have earned so far.', 'sic_box_show': 'TRUE', 'sic_box_x': -0.15, 'sic_box_y': -0.3, 'sic_box_width': 0.3, 'sic_box_height': 0.3}, {'sic_message': 'Petey is willing to walk only a certain number of steps during a block of trials, so if you wait too long to decide you will run out of steps more quickly and miss out on rewards. Petey also may have to take a certain number of steps before starting each trial.\nThis section shows the settings for the current block of trials', 'sic_box_show': 'TRUE', 'sic_box_x': 0.55, 'sic_box_y': -0.3, 'sic_box_width': 0.4, 'sic_box_height': 0.15}, {'sic_message': 'Petey is willing to walk only a certain number of steps during a block of trials, so if you wait too long to decide you will run out of steps more quickly and miss out on rewards. Petey also may have to take a certain number of steps before starting each trial.\nThis bar tells you how many more steps Petey has left. When the bar hits zero, the block will end.', 'sic_box_show': 'TRUE', 'sic_box_x': 0.15, 'sic_box_y': -0.3, 'sic_box_width': 0.3, 'sic_box_height': 0.3}, {'sic_message': &quot;So your performance will depend on both guessing correctly and not wasting too many steps.\nLet's get started!\nEach block will start with a description of the conditions.&quot;, 'sic_box_show': 'FALSE', 'sic_box_x': 0, 'sic_box_y': 0, 'sic_box_width': 0, 'sic_box_height': 0}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="Resources/PigeonStatusInstructionsConditions.xlsx" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="False" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="1" valType="num"/>
      <Param name="name" updates="None" val="status_instruction_loop" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="status_instruction_setup"/>
    <Routine name="show_message"/>
    <LoopTerminator name="status_instruction_loop"/>
    <LoopInitiator loopType="TrialHandler" name="experiment_loop">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'tc_task_type': 'predefined_commit', 'tc_block_name': 'lowSNRlowcost', 'tc_snr_set': 1, 'tc_steps_max': 1000, 'tc_steps_taken_to_start_trial': 1, 'tc_steps_lost_per_error': 0, 'tc_coins_max': 300, 'tc_coins_paid_to_start_trial': 0, 'tc_coins_lost_per_error': 0, 'tc_coins_gained_per_correct': 1, 'tc_predefined_bound_min_bonus': 0, 'tc_predefined_bound_max_bonus': 0.0025}, {'tc_task_type': 'predefined_commit', 'tc_block_name': 'lowSNRhicost', 'tc_snr_set': 1, 'tc_steps_max': 1000, 'tc_steps_taken_to_start_trial': 1, 'tc_steps_lost_per_error': 0, 'tc_coins_max': 50, 'tc_coins_paid_to_start_trial': 0, 'tc_coins_lost_per_error': 4, 'tc_coins_gained_per_correct': 1, 'tc_predefined_bound_min_bonus': 0.4, 'tc_predefined_bound_max_bonus': 0.6}, {'tc_task_type': 'predefined_commit', 'tc_block_name': 'highSNRlowcost', 'tc_snr_set': 2, 'tc_steps_max': 1000, 'tc_steps_taken_to_start_trial': 1, 'tc_steps_lost_per_error': 0, 'tc_coins_max': 400, 'tc_coins_paid_to_start_trial': 0, 'tc_coins_lost_per_error': 0, 'tc_coins_gained_per_correct': 1, 'tc_predefined_bound_min_bonus': 0, 'tc_predefined_bound_max_bonus': 0.01}, {'tc_task_type': 'predefined_commit', 'tc_block_name': 'highSNRhicost', 'tc_snr_set': 2, 'tc_steps_max': 1000, 'tc_steps_taken_to_start_trial': 1, 'tc_steps_lost_per_error': 0, 'tc_coins_max': 270, 'tc_coins_paid_to_start_trial': 0, 'tc_coins_lost_per_error': 4, 'tc_coins_gained_per_correct': 1, 'tc_predefined_bound_min_bonus': 0.13, 'tc_predefined_bound_max_bonus': 0.2}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="Resources/PigeonTaskConditions.xlsx" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
