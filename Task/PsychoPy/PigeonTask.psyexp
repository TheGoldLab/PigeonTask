      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="1000" valType="num"/>
      <Param name="name" updates="None" val="predefined_setup_loop" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="predefined_task_setup"/>
    <LoopTerminator name="predefined_setup_loop"/>
    <LoopInitiator loopType="TrialHandler" name="predefined_move_loop">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="None" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="False" valType="bool"/>
      <Param name="loopType" updates="None" val="random" valType="str"/>
      <Param name="nReps" updates="None" val="STEPS_MAX_PER_TRIAL" valType="num"/>
      <Param name="name" updates="None" val="predefined_move_loop" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="predefined_task_run"/>
    <LoopTerminator name="predefined_move_loop"/>
    <Routine name="show_message"/>
    <LoopTerminator name="predefined_trial_loop"/>
    <LoopTerminator name="experiment_loop"/>
    <Routine name="final_message"/>
    <Routine name="show_final_message"/>
  </Flow>
</PsychoPy2experiment>
