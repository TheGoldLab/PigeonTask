  <Flow>
    <Routine name="consent"/>
    <Routine name="experiment_setup"/>
    <LoopInitiator loopType="TrialHandler" name="general_instructions_loop">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'gic_message': 'Hi!\nThank you for participating in this experiment.\nPressing Esc will end this session.', 'gic_pigeon_show': False, 'gic_seeds_show': False}, {'gic_message': 'This is Petey the Pigeon.', 'gic_pigeon_show': True, 'gic_seeds_show': False}, {'gic_message': 'Petey is very hungry and sees two piles of seeds nearby. However, one pile is good and the other has gone bad.\nIn this task, you will see Petey walking back and forth between the piles to figure out which one he should eat. He will gradually tend toward the correct pile and remain there, but your job is to predict which pile that is before that happens.', 'gic_pigeon_show': True, 'gic_seeds_show': True}, {'gic_message': &quot;Let's see Petey move!&quot;, 'gic_pigeon_show': True, 'gic_seeds_show': True}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="Resources/PigeonGeneralInstructionsConditions.xlsx" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="False" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="1" valType="num"/>
      <Param name="name" updates="None" val="general_instructions_loop" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="general_instructions_setup"/>
    <Routine name="show_message"/>
    <LoopTerminator name="general_instructions_loop"/>
    <LoopInitiator loopType="TrialHandler" name="simple_demo_block_loop">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'sdc_message': 'Sometimes Petey will move quickly and directly towards one of the piles of seeds.', 'sdc_step_mean': 0.05, 'sdc_step_std': 0.1}, {'sdc_message': 'Sometimes Petey meanders a bit more.', 'sdc_step_mean': 0.02, 'sdc_step_std': 0.1}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="Resources/PigeonSimpleDemoConditions.xlsx" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="False" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="1" valType="num"/>
      <Param name="name" updates="None" val="simple_demo_block_loop" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
