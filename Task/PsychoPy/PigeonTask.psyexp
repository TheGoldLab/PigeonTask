      <KeyboardComponent name="pts_kbd_update" plugin="None">
        <Param val="'up','down','left','right','space', 'c'" valType="list" updates="constant" name="allowedKeys"/>
        <Param val="$correct_ans" valType="str" updates="constant" name="correctAns"/>
        <Param val="" valType="str" updates="None" name="deviceLabel"/>
